# Copy to .env for local development (the real .env is git-ignored).
# In production these are set in the Render dashboard instead.

# Flask session signing key. Use a long random string in production.
SECRET_KEY=change-me-to-a-long-random-string

# Postgres connection string (Neon). Leave UNSET locally to use the bundled SQLite DB.
# Example: postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
# DATABASE_URL=

# Set to 0 in production, 1 for local debugging.
FLASK_DEBUG=1
